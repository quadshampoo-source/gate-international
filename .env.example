# Copy to .env.local and fill in real values. Keep .env.local out of git.

# --- Supabase ---------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Email (Gmail SMTP) -----------------------------------------------------
# See docs/email-setup.md for App Password generation.
GMAIL_USER=hello@gateinternational.co
GMAIL_APP_PASSWORD=
EMAIL_FROM=Gate International <hello@gateinternational.co>
ADMIN_EMAIL=

# --- Analytics --------------------------------------------------------------
NEXT_PUBLIC_GA_ID=

# --- AI providers (server-only) --------------------------------------------
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
